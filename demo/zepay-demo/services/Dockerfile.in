# Shared Dockerfile for every Go demo service.
# The build script stages the service dir + go-common dir into a
# single tmp context. Inside the context:
#
#   /service/         service source (main.go, go.mod, etc.)
#   /go-common/       shared module the service depends on via
#                     `replace github.com/zepay/go-common => ../go-common`
#
# Working dir `/build/service` keeps the `..` in go.mod pointing at
# `/build/go-common` as the replace expects.

FROM golang:1.22-alpine AS build
WORKDIR /build

# go-common first so go mod download in service/ can resolve the replace.
COPY go-common /build/go-common

# Service source.
COPY service /build/service

WORKDIR /build/service
RUN go mod download
RUN CGO_ENABLED=0 GOOS=linux go build -trimpath -ldflags="-s -w" -o /out/app ./

FROM gcr.io/distroless/static-debian12:nonroot
COPY --from=build /out/app /app
EXPOSE 8080
ENTRYPOINT ["/app"]
