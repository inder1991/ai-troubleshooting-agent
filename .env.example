# Local-dev environment configuration.
#
# Copy this file to `.env` (gitignored) and fill the REQUIRED block.
# `make up` reads this file via docker compose.

# ─── Required ────────────────────────────────────────────────────────────────
# Get a key at https://console.anthropic.com/.
# Production deployments use multiple keys via the Helm chart; for local dev
# this single key is enough.
ANTHROPIC_API_KEY=

# ─── Postgres (bundled, defaults shown) ──────────────────────────────────────
POSTGRES_USER=ai_tshoot
POSTGRES_PASSWORD=ai_tshoot_dev
POSTGRES_DB=ai_tshoot
POSTGRES_PORT=5432

# ─── Redis (bundled, defaults shown) ─────────────────────────────────────────
REDIS_PASSWORD=ai_tshoot_dev
REDIS_PORT=6379

# ─── App ports (override if 8000/5173 are taken on your laptop) ──────────────
BACKEND_PORT=8000
FRONTEND_PORT=5173

# ─── Phase 4 feature flags (defaults match production-conservative legacy) ───
# Flip individually to test new code paths without a redeploy.
DIAGNOSTIC_PLANNER_MODE=legacy             # legacy | deterministic
DIAGNOSTIC_CONFIDENCE_MODE=deterministic   # deterministic | legacy
DIAGNOSTIC_CRITIC_MODE=legacy              # legacy | ensemble
DIAGNOSTIC_SIGNATURE_FAST_PATH=off         # off | on
DIAGNOSTIC_RESUME_ON_STARTUP=off           # off | on
