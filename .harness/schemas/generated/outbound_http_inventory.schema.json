{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "type": "object",
  "additionalProperties": false,
  "required": ["callsites"],
  "properties": {
    "callsites": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["file", "line", "url", "verb", "retry_decorated", "timeout_explicit"],
        "properties": {
          "file": {"type": "string"},
          "line": {"type": "integer"},
          "url": {"type": "string"},
          "verb": {"type": "string"},
          "retry_decorated": {"type": "boolean"},
          "timeout_explicit": {"type": "boolean"}
        }
      }
    }
  }
}
