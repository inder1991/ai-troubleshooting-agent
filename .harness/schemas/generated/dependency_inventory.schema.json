{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "type": "object",
  "additionalProperties": false,
  "required": ["python", "npm"],
  "properties": {
    "python": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["name", "version", "allowed", "on_spine"],
        "properties": {
          "name": {"type": "string"},
          "version": {"type": "string"},
          "allowed": {"type": "boolean"},
          "on_spine": {"type": "boolean"}
        }
      }
    },
    "npm": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["name", "version", "scope", "allowed", "on_spine"],
        "properties": {
          "name": {"type": "string"},
          "version": {"type": "string"},
          "scope": {"type": "string", "enum": ["runtime", "dev"]},
          "allowed": {"type": "boolean"},
          "on_spine": {"type": "boolean"}
        }
      }
    }
  }
}
